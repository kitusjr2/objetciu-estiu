generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Candidate {
  id        String   @id
  name      String
  nickname  String
  photo     String
  heLligat  Boolean  @default(false)
  lligatAt  DateTime?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id         String   @id @default(cuid())
  personId   String
  personName String
  action     String   // "lligat" or "desfer"
  createdAt  DateTime @default(now())
}
